"""
Type hints for benchmark tools.
"""

from typing import List
from shioaji import BaseContract

class BenchmarkResult:
    """Result from a benchmark operation."""
    
    count: int
    conversion_ns: int
    serialization_ns: int  
    total_ns: int
    size_bytes: int
    
    def __repr__(self) -> str: ...

class ContractBenchmark:
    """Performance benchmarking utilities for contract serialization."""
    
    def __new__(cls) -> ContractBenchmark: ...
    
    def serialize_contracts(self, contracts: List[BaseContract]) -> int:
        """
        Benchmark contract serialization with PyBaseContract → BaseContract conversion.
        
        Args:
            contracts: List of contracts to serialize
            
        Returns:
            Size of serialized data in bytes
        """
        ...
    
    def serialize_py_contracts_direct(self, contracts: List[BaseContract]) -> int:
        """
        Benchmark PyBaseContract direct serialization (no conversion).
        
        Args:
            contracts: List of contracts to serialize directly
            
        Returns:
            Size of serialized data in bytes
        """
        ...
    
    def serialize_contracts_detailed(self, contracts: List[BaseContract]) -> BenchmarkResult:
        """
        Detailed benchmark with timing breakdown for conversion approach.
        
        Args:
            contracts: List of contracts to serialize
            
        Returns:
            Detailed benchmark results including timing breakdown
        """
        ...
    
    def serialize_py_contracts_direct_detailed(self, contracts: List[BaseContract]) -> BenchmarkResult:
        """
        Detailed benchmark for PyBaseContract direct serialization.
        
        Args:
            contracts: List of contracts to serialize directly
            
        Returns:
            Detailed benchmark results for direct serialization
        """
        ...

__all__ = ["ContractBenchmark", "BenchmarkResult"]