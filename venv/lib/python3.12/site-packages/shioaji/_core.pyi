# Quote type string literals for market data subscription
QuoteTypeLiteral = Literal["tick", "bid_ask", "bidask", "quote"]

# Any contract type accepted by methods expecting BaseContract
ContractIdentifier = Union["BaseContract", "Contract", "Stock", "Future", "Option", "Index"]

# Enum string literals — accepted anywhere the corresponding enum wrapper is
# accepted (canonical shioaji pydantic `str -> Enum` parity, issue #186).
ActionLiteral = Literal["Buy", "Sell"]
StockPriceTypeLiteral = Literal["LMT", "MKT"]
FuturesPriceTypeLiteral = Literal["LMT", "MKT", "MKP"]
PriceTypeLiteral = Literal["LMT", "MKT", "MKP"]
OrderTypeLiteral = Literal["ROD", "IOC", "FOK"]
StockOrderLotLiteral = Literal["Common", "BlockTrade", "Fixing", "Odd", "IntradayOdd"]
StockOrderCondLiteral = Literal["Cash", "Netting", "MarginTrading", "ShortSelling", "Emerging"]
FuturesOCTypeLiteral = Literal["Auto", "New", "NewPosition", "Cover", "DayTrade"]
ComboTypeLiteral = Literal[
    "PriceSpread",
    "TimeSpread",
    "Straddle",
    "Strangle",
    "ConversionReversal",
    "WeeklyTimeSpread",
]
SecurityTypeLiteral = Literal["IND", "STK", "FUT", "OPT"]
ExchangeLiteral = Literal["TSE", "OTC", "OES", "TAIFEX", "TIM"]
UnitLiteral = Literal["Common", "Share"]

class EnumMixin:
    """Mixin providing common enum protocol methods."""
    @property
    def value(self) -> str: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...

class MappingMixin:
    """Mixin providing dict-like access for data structs."""
    def keys(self) -> List[str]: ...
    def __getitem__(self, key: str) -> Any: ...
    def __len__(self) -> int: ...
    def __contains__(self, key: str) -> bool: ...
    def dict(self) -> Dict[str, Any]: ...
    @property
    def __dict__(self) -> Dict[str, Any]:
        """DEPRECATED: returns a fresh dict each call. Use :meth:`dict` instead.

        Emits a :class:`DeprecationWarning` on every access. Mutations on the
        returned dict do NOT propagate back to this object (frozen pyclass).
        """
        ...

