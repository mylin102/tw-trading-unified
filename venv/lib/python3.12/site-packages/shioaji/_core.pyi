# =============================================================================
# Exception Types
# =============================================================================
#
# Exception hierarchy:
#
#   Exception (builtin)
#     └── ShioajiError
#           ├── AuthError                     # "Not authenticated" / "Login To Activate Ca"
#           │     └── TokenError              # HTTP 401
#           ├── SystemMaintenance             # HTTP 503
#           ├── ServerError                   # other non-200
#           ├── ValidationError              # HTTP 422
#           ├── BadRequestError              # HTTP 400
#           ├── CaError                       # CA certificate errors
#           │     ├── CaExpiredError           # CA has expired
#           │     └── CaPasswordError         # CA password incorrect
#           ├── AccountNotSignError           # account.signed is False
#           ├── SubscribeError               # Solace subscribe failed
#           ├── UnsubscribeError             # Solace unsubscribe failed
#           ├── ResponseError                # response processing error
#           │     ├── DecodeError            # msgpack parse failed
#           │     ├── ResponseMsgError       # can't extract Solace msg body
#           │     └── ResponseRecvError      # response channel closed
#           ├── ShioajiConnectionError        # + ConnectionError
#           ├── ShioajiTimeoutError           # + TimeoutError
#           ├── ShioajiValueError             # + ValueError
#           ├── ShioajiTypeError              # + TypeError
#           ├── AccountNotProvideError        # + ValueError
#           └── ShioajiPermissionError       # + PermissionError
#

class ShioajiError(Exception):
    """Base exception for all shioaji errors.

    Catch this to handle any shioaji-specific error.
    All shioaji exceptions inherit from this class.
    """
    ...

class AuthError(ShioajiError):
    """Raised when not authenticated.

    Common causes:
    - Calling API methods before login
    - Session expired or logged out
    """
    ...

class TokenError(AuthError):
    """Raised when authentication token is invalid or expired (HTTP 401).

    Also catchable via ``AuthError`` (parent class).
    """
    ...

class SystemMaintenance(ShioajiError):
    """Raised when the server is under maintenance (HTTP 503)."""
    ...

class ServerError(ShioajiError):
    """Raised when the server returns a non-200 error response."""
    ...

class ValidationError(ShioajiError):
    """Raised when the server returns a validation error (HTTP 422)."""
    ...

class BadRequestError(ShioajiError):
    """Raised when the server returns a bad request error (HTTP 400)."""
    ...

class CaError(ShioajiError):
    """Raised for certificate authority (CA) errors.

    Common causes:
    - CA certificate expired
    - CA not activated for person_id
    """
    ...

class CaExpiredError(CaError):
    """Raised when the CA certificate has expired.

    Also catchable via ``CaError`` (parent class).
    """
    ...

class CaPasswordError(CaError):
    """Raised when the CA certificate password is incorrect.

    Also catchable via ``CaError`` (parent class).
    """
    ...

class AccountNotSignError(ShioajiError):
    """Raised when account.signed is False for operations requiring CA signing.

    Reserve and earmarking operations require the account to be CA-signed.
    """
    ...

class SubscribeError(ShioajiError):
    """Raised when a Solace topic subscription fails.

    The error message includes contract details (security_type, exchange, code, quote_type).
    """
    ...

class UnsubscribeError(ShioajiError):
    """Raised when a Solace topic unsubscription fails.

    The error message includes contract details (security_type, exchange, code, quote_type).
    """
    ...

class ResponseError(ShioajiError):
    """Raised when a response from the server cannot be processed.

    Catch this to handle any response processing failure (decode, message extraction, channel errors).
    """
    ...

class DecodeError(ResponseError):
    """Raised when msgpack deserialization of a server response fails.

    Also catchable via ``ResponseError`` (parent class).
    """
    ...

class ResponseMsgError(ResponseError):
    """Raised when the binary attachment cannot be extracted from a Solace message.

    Also catchable via ``ResponseError`` (parent class).
    """
    ...

class ResponseRecvError(ResponseError):
    """Raised when the response channel is closed before a response arrives.

    Also catchable via ``ResponseError`` (parent class).
    """
    ...

class ShioajiConnectionError(ShioajiError, ConnectionError):
    """Raised when a network or transport error occurs.

    Also catchable via builtin ``ConnectionError``.

    Common causes:
    - Solace messaging connection failure
    - Network unreachable or DNS resolution failure
    """
    ...

class ShioajiTimeoutError(ShioajiError, TimeoutError):
    """Raised when a request times out.

    Also catchable via builtin ``TimeoutError``.

    Common causes:
    - API request exceeds the configured timeout
    - Contract fetch timeout
    """
    ...

class AccountNotProvideError(ShioajiError, ValueError):
    """Raised when no matching account is found for an API call.

    Also catchable via builtin ``ValueError``.
    """
    ...

class ShioajiValueError(ShioajiError, ValueError):
    """Raised for invalid values passed to shioaji APIs.

    Also catchable via builtin ``ValueError``.

    Common causes:
    - Invalid enum string (e.g., invalid quote type)
    - Mutually exclusive parameters provided together
    """
    ...

class ShioajiTypeError(ShioajiError, TypeError):
    """Raised for type mismatches in shioaji API arguments.

    Also catchable via builtin ``TypeError``.

    Common causes:
    - Callback is not callable
    - Async callback is not an async function
    - Wrong order type passed (expected StockOrder or FuturesOrder)
    """
    ...

class ShioajiPermissionError(ShioajiError, PermissionError):
    """Raised when the cache directory is not writable.

    Also catchable via builtin ``PermissionError``.

    Set ``SJ_CONTRACTS_PATH`` environment variable to a writable directory.
    """
    ...
